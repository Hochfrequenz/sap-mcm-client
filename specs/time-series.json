{
  "openapi": "3.0.2",
  "info": {
    "title": "Time Series",
    "version": "1.0.0",
    "description": "The Time Series API enables you to retrieve current and historical times series data and to delete time series data by time series-related identifiers.",
    "termsOfService": "https://www.sap.com/about/agreements/cloud-services.html?tag=language:english&search=Supplement&sort=title_asc&source=social-atw-mailto#pdf-asset=f4ccdd0a-107d-0010-87a3-c30de2ffd8ff&page=1"
  },
  "externalDocs": {
    "description": "API Guide of the TimeSeries",
    "url": "https://help.sap.com/docs/Cloud_for_Utilities_Foundation"
  },

  "servers": [
    {
      "url": "https://c4u-foundation-mcm-service.cfapps.{region}.hana.ondemand.com",
      "description": "Time Series Service",
      "variables": {
        "region": {
          "description": "Time Series Service",
          "enum" : [ "eu10", "ap10" ],
          "default": "eu10"
        }
      }
    }
  ],
