  "components": {
    "schemas": {
      "TimeSeriesDataHistoryValues": {
        "type": "object",
        "properties": {
          "ID": { "type": "string" },
          "importID": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "timeZoneCode": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "value": { "type": "number", "nullable": true },
          "missing": { "type": "boolean" },
          "quality": { "type": "string" },
          "timeSeriesID": { "type": "string" },
          "externalID": { "type": "string" }
        }
      },
      "TimeSeriesDataExtended": {
        "type": "object",
        "properties": {
          "ID": { "type": "string" },
          "importID": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "timeZoneCode": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "value": { "type": "number", "nullable": true },
          "missing": { "type": "boolean" },
          "quality": { "type": "string" },
          "timeSeriesID": { "type": "string" },
          "externalID": { "type": "string" }
        }
      },
      "DeleteTimeSeriesRequestDto": {
        "type": "object",
        "properties": {
          "uuids": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "List of time series UUIDs that are to be deleted"
          },
          "externalIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of externalIDs that are to be deleted"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "Start timestamp for deletion"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "End timestamp for deletion"
          }
        },
        "required": [
          "startTime",
          "endTime"
        ]
      }
    },
    "parameters": {
        "timeSeriesID":   {
          "name": "timeSeriesID",
          "in": "query",
          "required": true,
          "description": "The universally unique identifier (UUID) of a time series. Make sure that it is wrapped in single quotes, following the OData convention. Example: '123e4567-e89b-12d3-a456-426614174000'",
          "schema": {
            "type": "string",
            "example":  "'123e4567-e89b-12d3-a456-426614174000'"
          }
        },
        "externalID":   {
          "name": "externalID",
          "in": "query",
          "required": true,
          "description": "The external identifier of a time series. Make sure that it is wrapped in single quotes, following the OData convention. Example: '1+1-1:1.29.0'",
          "schema": {
            "type": "string",
            "example":  "'1+1-1:1.29.0'"
          }
        },
        "fromDate":   {
          "name": "fromDate",
          "in": "query",
          "required": true,
          "description": "The date in format YYYY-MM-DD. Make sure that it is wrapped in single quotes, following the OData convention. Example: '2025-02-01'",
          "schema": {
            "type": "string",
            "format": "date" ,
            "example":  "'2015-02-01'"
          }
        },
        "toDate":   {
          "name": "toDate",
          "in": "query",
          "required": true,
          "description": "The date in format YYYY-MM-DD. Make sure that it is wrapped in single quotes, following the OData convention. Example: '2025-02-28'",
          "schema": {
              "type": "string",
              "format": "date" ,
              "example":  "'2015-02-28'"
          }
        },
        "top": {
          "name": "$top",
          "in": "query",
          "description": "Display only the first n items. see [Paging - Top](http://docs.oasis-open.org/odata/odata/v4.01/odata-v4.01-part1-protocol.html#sec_SystemQueryOptiontop)",
          "schema": {
            "type": "integer",
            "minimum": 0
          },
          "example": 50
        },
        "skip": {
          "name": "$skip",
          "in": "query",
          "description": "Skip the first n items. see [Paging - Skip](http://docs.oasis-open.org/odata/odata/v4.01/odata-v4.01-part1-protocol.html#sec_SystemQueryOptionskip)",
          "schema": {
            "type": "integer",
            "minimum": 0
          }
        },
        "orderBy": {
          "name": "$orderby",
          "description": "Order items by property values. see [Sorting](http://docs.oasis-open.org/odata/odata/v4.01/odata-v4.01-part1-protocol.html#sec_SystemQueryOptionorderby)",
          "in": "query",
          "explode": false,
          "schema": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "ID",
                "importID",
                "timestamp",
                "timeZoneCode",
                "createdAt",
                "value",
                "missing",
                "quality",
                "timeSeriesID",
                "externalID"
              ]
            }
          }
        }
    },
    "responses": {
      "200DeleteByTimeSeriesID": {
        "description": "Successful Deletion.",
        "content": {
          "application/json": {
            "schema": {
              "example": {
                "rowCount": 150,
                "errorMessages": "",
                "results": [
                  {
                    "id": "123e4567-e89b-12d3-a456-426614174000",
                    "type": "TimeseriesId",
                    "success": true,
                    "rawCount": 150,
                    "httpStatus": "OK"
                  }
                ]
              }
            }
          }
        }
      },
      "200DeleteByExternalID": {
        "description": "Successful Deletion.",
        "content": {
          "application/json": {
            "schema": {
              "example": {
                "rowCount": 150,
                "errorMessages": "",
                "results": [
                  {
                    "id": "1+1-1:1.29.0",
                    "type": "ExternalId",
                    "success": true,
                    "rawCount": 150,
                    "httpStatus": "OK"
                  }
                ]
              }
            }
          }
        }
      },
      "204": {
        "description": "Successfully deleted. No content is returned."
      },
      "401": {
        "description": "Unauthorized. There is a problem with your access token. Generate a new JSON Web Token (JWT) as described in the [Administration Guide]( https://help.sap.com/docs/Cloud_for_Utilities_Foundation/39a9e8c04a4943b69d6851aefcdf0f4d/416202c8d4a449dbae5ac7cdfe40f3c3.html?locale=en-US&version=Cloud)."
      },
      "BadRequestFileUpload": {
        "description": "Bad request due to file upload problem",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "object",
                  "properties": {
