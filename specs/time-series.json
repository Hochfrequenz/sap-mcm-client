          }
        ],
        "responses": {
          "200": {
            "description": "Retrieved historical time series data values.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TimeSeriesDataHistoryValues" } }
