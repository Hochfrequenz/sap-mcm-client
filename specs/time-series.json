    "/api/v1/timeseries/uploadsc": {
      "post": {
        "summary": "Uploads a time series file using a shortcut for the file name-based upload of ID extraction.",
        "tags": ["Upload TimeSeriesData"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/204"
          },
          "401": {
