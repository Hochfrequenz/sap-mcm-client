# SAP Cloud for Utilities Foundation — MCM service credentials
#
# Copy this file to .env and fill in your values. The .env file is
# gitignored. The recorded responses ARE committed (they're business
# data, not secrets).
#
# All four values come from your SAP BTP service binding.

# Service base URL (region-specific, e.g. eu10 or ap10)
SAP_MCM_BASE_URL=https://c4u-foundation-mcm-service.cfapps.eu10.hana.ondemand.com

# OAuth2 token endpoint — service binding uaa.url + /oauth/token
SAP_MCM_TOKEN_URL=https://your-subaccount.authentication.eu10.hana.ondemand.com/oauth/token

# OAuth2 client id — service binding uaa.clientid
SAP_MCM_CLIENT_ID=sb-xsuaa-xxxxx!b12345|mcm-service!b67890

# OAuth2 client secret — service binding uaa.clientsecret
SAP_MCM_CLIENT_SECRET=your-secret-here

# Optional: UUIDs of specific records to record.
# If left empty, the script will pick the first instance/class/model
# returned by a list call.
SAP_MCM_INSTANCE_ID=
SAP_MCM_CLASS_ID=
SAP_MCM_MODEL_ID=
